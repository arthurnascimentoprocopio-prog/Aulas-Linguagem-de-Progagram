

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema Escolar - EEB Dom Jaime de Barros Câmara</title>
    <style>
        :root {
            --primary-blue: #fd0000ee;
            --secondary-blue: #000000;
            --accent-light: #b7d6ff;
            --accent-cyan: #dd8f89;
            --white: #ffffff;
            --text-gray: #000000;
            --shadow: 0 4px 6px rgba(255, 19, 19, 0.1);
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1d1919 0%, #d1d9ff 100%);
            min-height: 100vh;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            color: #ffffff;
        }

        .pagina {
            background: linear-gradient(90deg, var(--primary-blue), var(--secondary-blue));
            width: 100%;
            max-width: 500px;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgb(206, 2, 2);
            color: var(--white);
            display: none;
        }
        .pagina-ativa { 
            display: block;
        }

        .titulo-principal {
            font-size: 24px;
            margin: 0 0 10px 0;
            text-align: center;
            font-weight: bold;
        }

        .subtitulo {
            font-size: 14px;
            text-align: center;
            margin-bottom: 25px;
            opacity: 0.9;
        }

        .campo-grupo {
            margin-bottom: 15px;
            display: flex;
            flex-direction: column;
        }

        label {
            margin-bottom: 5px;
            font-size: 14px;
            font-weight: 500;
        }

        input {
            padding: 12px 15px;
            border: none;
            border-radius: 25px;
            background: linear-gradient(180deg, var(--accent-light), var(--accent-cyan));
            font-size: 14px;
            outline: none;
            transition: box-shadow 0.3s ease;
        }

        input:focus {
            box-shadow: 0 0 0 3px rgba(163, 255, 255, 0.4);
        }

        .btn-cadastrar {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            border: none;
            border-radius: 25px;
            background: linear-gradient(180deg, var(--accent-light), var(--accent-cyan));
            font-weight: bold;
            color: var(--primary-blue);
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-cadastrar:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        .btn-cadastrar:active {
            transform: translateY(1px);
        }

        .resultado {
            background: linear-gradient(180deg, #1a1a1a, #c23e16);
            width: 100%;
            max-width: 460px;
            padding: 25px;
            border-radius: 12px;
            margin-top: 30px;
            display: none;
            color: var(--white);
            box-shadow: var(--shadow);
            animation: fadeIn 0.5s ease-out;
        }

        .resultado h2 {
            margin-top: 0;
            font-size: 18px;
            border-bottom: 1px solid rgba(13, 106, 168, 0.2);
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

        .resultado p {
            margin: 8px 0;
            font-size: 14px;
            line-height: 1.5;
        }

        .resultado strong {
            color: var(--accent-cyan);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 600px) {
            .formulario-container {
                padding: 20px;
            }
        }

        .menu {
            background: linear-gradient(to left,rgb(0, 0, 0) 10%,rgb(255, 0, 0) 33%);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 40px;
            height: 60px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .menu-esquerda {
            flex: 1;
            display: flex;
            align-items: center;
            color: var(--white);
            font-weight: bold;
            font-size: 1.2rem;
        }

        .menu-esquerda::before {
            content: "🏫 ";
        }

        .menu-centro {
            flex: 2;
            display: flex;
            justify-content: center;
            gap: 25px;
        }

        .menu-centro span {
            color: #0f74df;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            padding: 8px 12px;
            border-radius: 6px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .menu-centro span:hover {
            color: var(--white);
            background-color: rgb(100, 193, 255);
        }

        .menu-direita {
            flex: 1;
            display: flex;
            justify-content: flex-end;
        }

        .menu-direita span {
            background-color: gray;
            color: var(--white);
            padding: 8px 25px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 14px;
            cursor: pointer;
            transition: background 0.3s;
        }

        .menu-direita span:hover {
            background-color: #2980b9;
        }


    </style>
</head>

<body>

<div class="menu">
        <div class="menu-esquerda">EEB DOM JAIME</div>
        <div class="menu-centro">
            <span>Início</span>
            <span>Alunos</span>
            <span>Professores</span>
            <span>Funcionários</span>
        </div>
        <div class="menu-direita">
            <span>Login</span>
        </div>
    </div>



