    <script>
        function mostrarDados() {
            const dados = {
                nome: document.getElementById("nome").value,
                dataNasc: document.getElementById("dataNasc").value,
                cpf: document.getElementById("cpf").value,
                email: document.getElementById("email").value,
                estado: document.getElementById("estado").value,
                cep: document.getElementById("cep").value,
                idade: document.getElementById("idade").value
            };

            if (!dados.nome || !dados.email) {
                alert("Por favor, preencha os campos obrigatórios.");
                return;
            }

            const dataFormatada = dados.dataNasc.split('-').reverse().join('/');

            const resultadoDiv = document.getElementById("resultado");
            resultadoDiv.innerHTML = `
                <h2>Dados Cadastrados com Sucesso</h2>
                <p><strong>Nome:</strong> ${dados.nome}</p>
                <p><strong>Data de Nascimento:</strong> ${dataFormatada}</p>
                <p><strong>CPF:</strong> ${dados.cpf}</p>
                <p><strong>Email:</strong> ${dados.email}</p>
                <p><strong>Estado:</strong> ${dados.estado}</p>
                <p><strong>CEP:</strong> ${dados.cep}</p>
                <p><strong>Idade:</strong> ${dados.idade} anos</p>
            `;

            resultadoDiv.style.display = "block";

            resultadoDiv.scrollIntoView({ behavior: 'smooth' });
        }
    </script>
